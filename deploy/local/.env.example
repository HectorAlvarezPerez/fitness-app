# Opcional: déjalo vacío para usar mismo dominio/origen donde esté publicada la app
# VITE_SUPABASE_URL=

# Anon key del Supabase local (usa la que ya tienes en .env.local)
VITE_SUPABASE_ANON_KEY=replace_me

# Token del túnel Cloudflare (Dashboard -> Zero Trust -> Tunnels -> <tu tunnel> -> token)
CLOUDFLARE_TUNNEL_TOKEN=replace_me
